FUNCTION_APP_URL=https://your-function-app.azurewebsites.net
HTTP_POST_CODE=your-function-host-key

# Office 365 Users connection runtime URL — required for IN-ORG sender badging and
# profile enrichment (job title, department, manager). Set this to the runtime URL of
# the office365users connection from your Connector Namespace, or leave empty to omit enrichment.
OFFICE365USERS_CONNECTION_RUNTIME_URL=

# Optional. Comma-separated list of email domains considered internal/in-org.
# Senders whose domain matches will be looked up via the Office 365 Users connector
# for IN-ORG badging and profile enrichment (job title, department, manager).
# Senders outside these domains are treated as EXTERNAL and skip the API call.
# Leave empty to look up every sender.
# Example: INTERNAL_DOMAINS=microsoft.com,contoso.com
INTERNAL_DOMAINS=
